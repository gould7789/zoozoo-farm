<%# 館詳細ページ — 所属動物一覧を表示 %>
<%# @animals: active=trueの動物を種名・個体名順で表示 %>

<div class="max-w-2xl md:max-w-4xl mx-auto">

  <%# ヘッダー — 戻るリンク・タイトル・動物追加ボタン %>
  <div class="flex items-center justify-between mb-6 bg-white/80 backdrop-blur-sm rounded-xl px-5 py-4 shadow-sm">
    <div class="flex items-center gap-3 min-w-0">
      <%= link_to zones_path, class: "text-gray-400 hover:text-gray-600 transition-colors shrink-0" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      <% end %>
      <div class="min-w-0">
        <h1 class="text-xl font-bold text-gray-900 truncate"><%= @zone.name %></h1>
        <% if @zone.description.present? %>
          <p class="text-sm text-gray-500 mt-0.5 line-clamp-1"><%= @zone.description %></p>
        <% end %>
      </div>
    </div>
    <% if current_user.admin? %>
      <%= link_to new_zone_animal_path(@zone),
          class: "shrink-0 ml-3 inline-flex items-center gap-1.5 h-9 px-3 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        추가
      <% end %>
    <% end %>
  </div>

  <%# 動物リスト — モバイル: カード / デスクトップ: テーブル %>
  <% if @animals.empty? %>
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
      <p class="text-gray-400 text-sm">등록된 동물이 없습니다.</p>
    </div>
  <% else %>

    <%# 検索フィールド — data-controller="search" で動物リストをフィルタリング %>
    <div data-controller="search" class="mb-4">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <input type="text"
               placeholder="종 이름 또는 개체명으로 검색"
               class="w-full h-10 pl-9 pr-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-500 bg-white"
               data-search-target="input"
               data-action="input->search#filter">
      </div>

      <%# モバイルカードリスト %>
      <div class="space-y-3 md:hidden mt-4">
        <% @animals.each do |animal| %>
          <%= link_to zone_animal_path(@zone, animal),
              class: "bg-white rounded-xl border border-gray-200 p-4 shadow-sm hover:shadow-md transition-all flex items-center justify-between block",
              data: { search_target: "item", search_text: "#{animal.species} #{animal.name}" } do %>
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= animal.species %></p>
              <% if animal.name.present? %>
                <p class="text-xs text-gray-500 mt-0.5"><%= animal.name %></p>
              <% end %>
            </div>
            <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          <% end %>
        <% end %>
        <p data-search-target="empty" class="hidden text-center text-gray-400 text-sm py-8">검색 결과가 없습니다.</p>
      </div>

      <%# デスクトップテーブル %>
      <div class="hidden md:block bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mt-4">
        <table class="w-full text-sm table-fixed">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="w-48 text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">종 이름</th>
              <th class="w-36 text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">개체명</th>
              <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">성별</th>
              <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">CITES</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @animals.each do |animal| %>
              <tr class="hover:bg-gray-50 cursor-pointer"
                  data-controller="row-link"
                  data-row-link-url-value="<%= zone_animal_path(@zone, animal) %>"
                  data-action="click->row-link#navigate"
                  data-search-target="item"
                  data-search-text="<%= "#{animal.species} #{animal.name}" %>">
                <td class="px-5 py-3.5 font-medium text-gray-900"><%= animal.species %></td>
                <td class="px-5 py-3.5 text-gray-500 text-center"><%= animal.name.presence || "—" %></td>
                <td class="px-5 py-3.5 text-gray-500 text-center"><%= ({ "male" => "수컷", "female" => "암컷", "unknown" => "미확인" })[animal.gender] %></td>
                <td class="px-5 py-3.5 text-gray-500 text-center"><%= animal.cites_grade == "none" ? "—" : animal.cites_grade.upcase %></td>
              </tr>
            <% end %>
            <tr data-search-target="empty" class="hidden">
              <td colspan="4" class="px-5 py-8 text-center text-gray-400 text-sm">검색 결과가 없습니다.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  <% end %>

</div>
