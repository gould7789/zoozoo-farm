<%# 給餌記録新規作成ページ %>

<div class="max-w-lg mx-auto">

  <div class="flex items-center gap-3 mb-6">
    <%= link_to zone_animal_feeding_records_path(@zone, @animal), class: "text-gray-400 hover:text-gray-600 transition-colors shrink-0" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
    <% end %>
    <div>
      <p class="text-xs text-gray-400"><%= @animal.species %></p>
      <h1 class="text-xl font-bold text-gray-900">먹이 기록 추가</h1>
    </div>
  </div>

  <%= render "form", feeding_record: @feeding_record %>

</div>
