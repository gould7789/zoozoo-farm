<%# 館詳細ページ — カテゴリ別アコーディオン表示 %>
<% content_for(:title) { @zone.name } %>

<div class="max-w-2xl md:max-w-4xl mx-auto">

  <%# ヘッダー — 戻るリンク・タイトル・動物追加ボタン %>
  <div class="flex items-center justify-between mb-4 bg-white/80 backdrop-blur-sm rounded-xl px-5 py-4 shadow-sm">
    <div class="flex items-center gap-3 min-w-0">
      <%= link_to zones_path, class: "text-gray-400 hover:text-gray-600 transition-colors shrink-0" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      <% end %>
      <div class="min-w-0">
        <h1 class="text-xl font-bold text-gray-900 truncate"><%= @zone.name %></h1>
        <% if @zone.description.present? %>
          <p class="text-sm text-gray-500 mt-0.5 line-clamp-1"><%= @zone.description %></p>
        <% end %>
      </div>
    </div>
    <% if current_user.admin? %>
      <%= link_to new_zone_animal_path(@zone),
          class: "shrink-0 ml-3 inline-flex items-center gap-1.5 h-9 px-3 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        추가
      <% end %>
    <% end %>
  </div>

  <%# Admin専用 — カテゴリ追加フォーム %>
  <% if current_user.admin? %>
    <div class="mb-4 bg-white rounded-xl border border-gray-200 px-5 py-4 shadow-sm">
      <p class="text-sm font-medium text-gray-700 mb-2">카테고리 추가</p>
      <%= form_with model: [ @zone, @new_category ], class: "flex gap-2" do |f| %>
        <%= f.text_field :name,
            placeholder: "카테고리 이름 (예: 알파카)",
            class: "flex-1 h-10 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-500" %>
        <%= f.submit "추가",
            class: "h-10 px-4 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
      <% end %>
    </div>
  <% end %>

  <%# 全動物なしの場合 %>
  <% if @animals_by_category.empty? %>
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
      <p class="text-gray-400 text-sm">등록된 동물이 없습니다.</p>
    </div>
  <% else %>

    <%# カテゴリ別アコーディオン %>
    <% @categories.each do |category| %>
      <% animals = @animals_by_category[category.id] %>
      <% next if animals.blank? %>

      <details class="bg-white rounded-xl border border-gray-200 shadow-sm mb-3 group" open>
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none select-none">
          <div class="flex items-center gap-2">
            <%# 開閉アイコン %>
            <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-90 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
            <span class="font-semibold text-gray-900"><%= category.name %></span>
            <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">
              <%= animals.sum(&:individual_count) %>마리
            </span>
          </div>
          <%# Admin: カテゴリ削除ボタン %>
          <% if current_user.admin? %>
            <%= button_to zone_animal_category_path(@zone, category),
                method: :delete,
                data: { turbo_confirm: "카테고리를 삭제하면 동물은 미분류로 이동됩니다. 계속하시겠습니까?" },
                form: { class: "contents" },
                class: "text-xs text-red-400 hover:text-red-600 px-2 py-1 rounded transition-colors ml-2 shrink-0" do %>
              삭제
            <% end %>
          <% end %>
        </summary>

        <%# 동물 목록 — 모바일: 카드 / 데스크탑: 테이블 %>
        <div class="border-t border-gray-100">

          <%# モバイルカードリスト %>
          <div class="space-y-2 md:hidden px-4 py-3">
            <% animals.each do |animal| %>
              <% condition = animal.latest_condition %>
              <%= link_to zone_animal_path(@zone, animal),
                  class: "flex items-center justify-between py-2 px-1",
                  data: { search_target: "item", search_text: "#{animal.species} #{animal.name}" } do %>
                <div class="min-w-0">
                  <div class="flex items-center gap-1.5 flex-wrap">
                    <% if animal.individual_count > 1 %>
                      <span class="text-xs bg-blue-100 text-blue-600 font-medium px-1.5 py-0.5 rounded"><%= animal.individual_count %>마리</span>
                    <% end %>
                    <p class="text-sm font-semibold text-gray-900"><%= animal.name.presence || animal.species %></p>
                    <% if animal.name.present? %>
                      <p class="text-xs text-gray-400">(<%= animal.species %>)</p>
                    <% end %>
                  </div>
                  <div class="flex items-center gap-2 mt-1">
                    <span class="text-xs text-gray-400"><%= ({ "male" => "수컷", "female" => "암컷", "unknown" => "미확인" })[animal.gender] %></span>
                    <% if animal.age %>
                      <span class="text-xs text-gray-400"><%= animal.age %>살</span>
                    <% end %>
                    <% if condition %>
                      <%
                        badge = case condition
                        when "normal"  then { text: "정상", cls: "bg-green-100 text-green-700" }
                        when "caution" then { text: "주의", cls: "bg-yellow-100 text-yellow-700" }
                        when "danger"  then { text: "위험", cls: "bg-red-100 text-red-700" }
                        end
                      %>
                      <span class="inline-block px-1.5 py-0.5 rounded text-xs font-medium <%= badge[:cls] %>"><%= badge[:text] %></span>
                    <% end %>
                  </div>
                </div>
                <svg class="w-4 h-4 text-gray-400 shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              <% end %>
            <% end %>
          </div>

          <%# デスクトップテーブル %>
          <div class="hidden md:block">
            <table class="w-full text-sm table-fixed">
              <thead class="bg-gray-50">
                <tr>
                  <th class="w-1/5 text-left px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">종 이름</th>
                  <th class="w-1/5 text-center px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">개체명</th>
                  <th class="w-1/6 text-center px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">개체수</th>
                  <th class="w-1/6 text-center px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">성별</th>
                  <th class="w-1/6 text-center px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">나이</th>
                  <th class="w-1/6 text-center px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">건강 상태</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% animals.each do |animal| %>
                  <% condition = animal.latest_condition %>
                  <tr class="hover:bg-gray-50 cursor-pointer"
                      data-controller="row-link"
                      data-row-link-url-value="<%= zone_animal_path(@zone, animal) %>"
                      data-action="click->row-link#navigate"
                      data-search-target="item"
                      data-search-text="<%= "#{animal.species} #{animal.name}" %>">
                    <td class="px-4 py-3 font-medium text-gray-900 truncate"><%= animal.species %></td>
                    <td class="px-4 py-3 text-gray-500 text-center truncate"><%= animal.name.presence || "—" %></td>
                    <td class="px-4 py-3 text-center">
                      <% if animal.individual_count > 1 %>
                        <span class="inline-block bg-blue-100 text-blue-600 text-xs font-medium px-2 py-0.5 rounded-full"><%= animal.individual_count %>마리</span>
                      <% else %>
                        <span class="text-gray-400">—</span>
                      <% end %>
                    </td>
                    <td class="px-4 py-3 text-gray-500 text-center"><%= ({ "male" => "수컷", "female" => "암컷", "unknown" => "미확인" })[animal.gender] %></td>
                    <td class="px-4 py-3 text-gray-500 text-center"><%= animal.age ? "#{animal.age}살" : "—" %></td>
                    <td class="px-4 py-3 text-center">
                      <% if condition %>
                        <%
                          badge = case condition
                          when "normal"  then { text: "정상", cls: "bg-green-100 text-green-700" }
                          when "caution" then { text: "주의", cls: "bg-yellow-100 text-yellow-700" }
                          when "danger"  then { text: "위험", cls: "bg-red-100 text-red-700" }
                          end
                        %>
                        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium <%= badge[:cls] %>"><%= badge[:text] %></span>
                      <% else %>
                        <span class="text-gray-400">—</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

        </div>
      </details>
    <% end %>

    <%# 未分類セクション %>
    <% if @animals_by_category[nil].present? %>
      <% uncategorized = @animals_by_category[nil] %>
      <details class="bg-white rounded-xl border border-dashed border-gray-300 shadow-sm mb-3 group" open>
        <summary class="flex items-center gap-2 px-5 py-4 cursor-pointer list-none select-none">
          <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-90 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
          <span class="font-semibold text-gray-500">미분류</span>
          <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">
            <%= uncategorized.sum(&:individual_count) %>마리
          </span>
        </summary>

        <div class="border-t border-gray-100">

          <%# モバイルカードリスト %>
          <div class="space-y-2 md:hidden px-4 py-3">
            <% uncategorized.each do |animal| %>
              <% condition = animal.latest_condition %>
              <%= link_to zone_animal_path(@zone, animal),
                  class: "flex items-center justify-between py-2 px-1",
                  data: { search_target: "item", search_text: "#{animal.species} #{animal.name}" } do %>
                <div class="min-w-0">
                  <div class="flex items-center gap-1.5 flex-wrap">
                    <% if animal.individual_count > 1 %>
                      <span class="text-xs bg-blue-100 text-blue-600 font-medium px-1.5 py-0.5 rounded"><%= animal.individual_count %>마리</span>
                    <% end %>
                    <p class="text-sm font-semibold text-gray-900"><%= animal.name.presence || animal.species %></p>
                    <% if animal.name.present? %>
                      <p class="text-xs text-gray-400">(<%= animal.species %>)</p>
                    <% end %>
                  </div>
                  <div class="flex items-center gap-2 mt-1">
                    <span class="text-xs text-gray-400"><%= ({ "male" => "수컷", "female" => "암컷", "unknown" => "미확인" })[animal.gender] %></span>
                    <% if animal.age %>
                      <span class="text-xs text-gray-400"><%= animal.age %>살</span>
                    <% end %>
                    <% if condition %>
                      <%
                        badge = case condition
                        when "normal"  then { text: "정상", cls: "bg-green-100 text-green-700" }
                        when "caution" then { text: "주의", cls: "bg-yellow-100 text-yellow-700" }
                        when "danger"  then { text: "위험", cls: "bg-red-100 text-red-700" }
                        end
                      %>
                      <span class="inline-block px-1.5 py-0.5 rounded text-xs font-medium <%= badge[:cls] %>"><%= badge[:text] %></span>
                    <% end %>
                  </div>
                </div>
                <svg class="w-4 h-4 text-gray-400 shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              <% end %>
            <% end %>
          </div>

          <%# デスクトップテーブル %>
          <div class="hidden md:block">
            <table class="w-full text-sm table-fixed">
              <thead class="bg-gray-50">
                <tr>
                  <th class="w-1/5 text-left px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">종 이름</th>
                  <th class="w-1/5 text-center px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">개체명</th>
                  <th class="w-1/6 text-center px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">개체수</th>
                  <th class="w-1/6 text-center px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">성별</th>
                  <th class="w-1/6 text-center px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">나이</th>
                  <th class="w-1/6 text-center px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">건강 상태</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% uncategorized.each do |animal| %>
                  <% condition = animal.latest_condition %>
                  <tr class="hover:bg-gray-50 cursor-pointer"
                      data-controller="row-link"
                      data-row-link-url-value="<%= zone_animal_path(@zone, animal) %>"
                      data-action="click->row-link#navigate"
                      data-search-target="item"
                      data-search-text="<%= "#{animal.species} #{animal.name}" %>">
                    <td class="px-4 py-3 font-medium text-gray-900 truncate"><%= animal.species %></td>
                    <td class="px-4 py-3 text-gray-500 text-center truncate"><%= animal.name.presence || "—" %></td>
                    <td class="px-4 py-3 text-center">
                      <% if animal.individual_count > 1 %>
                        <span class="inline-block bg-blue-100 text-blue-600 text-xs font-medium px-2 py-0.5 rounded-full"><%= animal.individual_count %>마리</span>
                      <% else %>
                        <span class="text-gray-400">—</span>
                      <% end %>
                    </td>
                    <td class="px-4 py-3 text-gray-500 text-center"><%= ({ "male" => "수컷", "female" => "암컷", "unknown" => "미확인" })[animal.gender] %></td>
                    <td class="px-4 py-3 text-gray-500 text-center"><%= animal.age ? "#{animal.age}살" : "—" %></td>
                    <td class="px-4 py-3 text-center">
                      <% if condition %>
                        <%
                          badge = case condition
                          when "normal"  then { text: "정상", cls: "bg-green-100 text-green-700" }
                          when "caution" then { text: "주의", cls: "bg-yellow-100 text-yellow-700" }
                          when "danger"  then { text: "위험", cls: "bg-red-100 text-red-700" }
                          end
                        %>
                        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium <%= badge[:cls] %>"><%= badge[:text] %></span>
                      <% else %>
                        <span class="text-gray-400">—</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

        </div>
      </details>
    <% end %>

  <% end %>

</div>
