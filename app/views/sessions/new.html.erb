<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Zoo Zoo Farm</h1>
      <p class="mt-2 text-sm text-gray-600">사육사 관리 시스템</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <% if flash[:alert] %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: login_path, method: :post do |f| %>
        <div class="mb-4">
          <%= f.label :email, "이메일", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email,
              class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-blue-500",
              placeholder: "email@example.com",
              autocomplete: "email",
              required: true %>
        </div>

        <%# パスワード表示切り替え — data-controller="password" %>
        <div class="mb-6" data-controller="password">
          <%= f.label :password, "비밀번호", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="relative">
            <%= f.password_field :password,
                class: "w-full h-11 px-3 pr-11 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-blue-500",
                autocomplete: "current-password",
                required: true,
                data: { password_target: "input" } %>
            <button type="button"
                    class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-400 hover:text-gray-600"
                    data-action="click->password#toggle">
              <%# 비밀번호 숨김 상태 아이콘 (기본 표시) %>
              <svg data-password-target="eyeOff" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
              </svg>
              <%# 비밀번호 표시 상태 아이콘 (숨김) %>
              <svg data-password-target="eyeOn" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </button>
          </div>
        </div>

        <%= f.submit "로그인",
            class: "w-full h-11 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg text-base cursor-pointer transition-colors" %>
      <% end %>
    </div>
  </div>
</div>
