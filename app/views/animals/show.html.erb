<%# 動物詳細ページ — 個体プロフィールを表示 %>
<%# 編集・削除ボタンはAdmin専用 %>
<h1><%= @animal.species %><% if @animal.name.present? %>（<%= @animal.name %>）<% end %></h1>

<p>관: <%= link_to @zone.name, zone_path(@zone) %></p>
<p>성별: <%= @animal.gender %></p>
<% if @animal.birth_date.present? %>
  <p>생년월일: <%= @animal.birth_date %></p>
<% end %>
<% if @animal.acquired_at.present? %>
  <p>입수일: <%= @animal.acquired_at %></p>
<% end %>
<p>CITES: <%= @animal.cites_grade %></p>
<% if @animal.note.present? %>
  <p>특이사항: <%= @animal.note %></p>
<% end %>

<%# 編集・削除はAdmin専用 — Staffには非表示 %>
<% if current_user.admin? %>
  <%= link_to "수정", edit_zone_animal_path(@zone, @animal) %>
  <%= button_to "삭제", zone_animal_path(@zone, @animal), method: :delete,
        data: { turbo_confirm: "정말 삭제하시겠습니까?" } %>
<% end %>
