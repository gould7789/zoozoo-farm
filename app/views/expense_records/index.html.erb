<%# 支出記録一覧ページ — Admin専用 %>

<div class="max-w-2xl lg:max-w-4xl mx-auto">

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">지출 기록</h1>
    <%= link_to new_expense_record_path,
        class: "inline-flex items-center gap-1.5 h-9 px-3 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      추가
    <% end %>
  </div>

  <%# 今月の合計サマリーカード %>
  <% this_month = @expense_records.select { |er| er.spent_on >= Date.today.beginning_of_month } %>
  <% monthly_total = this_month.sum(&:amount) %>
  <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
    <p class="text-xs font-medium text-red-600 mb-1">이번 달 총 지출</p>
    <p class="text-2xl font-bold text-red-900"><%= number_with_delimiter(monthly_total) %>원</p>
    <p class="text-xs text-red-400 mt-0.5"><%= Date.today.strftime("%Y년 %m월") %> · <%= this_month.size %>건</p>
  </div>

  <% if @expense_records.empty? %>
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
      <p class="text-gray-400 text-sm">지출 기록이 없습니다.</p>
    </div>
  <% else %>

    <%# カテゴリラベルの定義 %>
    <% category_label = {
      "animal_purchase" => ["동물 구매비", "bg-purple-100 text-purple-700"],
      "food"            => ["먹이 구매비", "bg-green-100 text-green-700"],
      "medical"         => ["병원비", "bg-blue-100 text-blue-700"],
      "disposal"        => ["시체 처리비", "bg-gray-100 text-gray-600"],
      "maintenance"     => ["시설 유지보수", "bg-yellow-100 text-yellow-700"],
      "other"           => ["기타", "bg-orange-100 text-orange-700"]
    } %>

    <%# モバイルカードリスト %>
    <div class="space-y-3 lg:hidden">
      <% @expense_records.each do |er| %>
        <% label = category_label[er.category] || [er.category, "bg-gray-100 text-gray-600"] %>
        <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
          <div class="flex items-start justify-between mb-2">
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= er.spent_on.strftime("%Y-%m-%d") %></p>
              <span class="inline-block mt-1 px-2 py-0.5 text-xs font-medium rounded-full <%= label[1] %>">
                <%= label[0] %>
              </span>
            </div>
            <p class="text-lg font-bold text-gray-900"><%= number_with_delimiter(er.amount) %>원</p>
          </div>
          <p class="text-sm text-gray-600"><%= er.description %></p>
          <div class="flex gap-2 mt-3 pt-3 border-t border-gray-100">
            <%= link_to "수정", edit_expense_record_path(er),
                class: "flex-1 inline-flex items-center justify-center h-9 text-xs font-medium text-gray-600 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors" %>
            <%= button_to "삭제", expense_record_path(er),
                method: :delete,
                data: { turbo_confirm: "정말 삭제하시겠습니까?" },
                class: "flex-1 inline-flex items-center justify-center h-9 text-xs font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>

    <%# デスクトップテーブル %>
    <div class="hidden lg:block bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">날짜</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">종류</th>
            <th class="text-right px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">지출액</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">내용</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @expense_records.each do |er| %>
            <% label = category_label[er.category] || [er.category, "bg-gray-100 text-gray-600"] %>
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-3.5 font-medium text-gray-900"><%= er.spent_on.strftime("%Y-%m-%d") %></td>
              <td class="px-5 py-3.5">
                <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full <%= label[1] %>">
                  <%= label[0] %>
                </span>
              </td>
              <td class="px-5 py-3.5 text-right font-semibold text-gray-900"><%= number_with_delimiter(er.amount) %>원</td>
              <td class="px-5 py-3.5 text-gray-500 max-w-xs truncate"><%= er.description %></td>
              <td class="px-5 py-3.5">
                <div class="flex items-center gap-2 justify-end">
                  <%= link_to "수정", edit_expense_record_path(er), class: "text-xs text-blue-600 hover:underline" %>
                  <%= button_to "삭제", expense_record_path(er),
                      method: :delete,
                      data: { turbo_confirm: "정말 삭제하시겠습니까?" },
                      class: "text-xs text-red-500 hover:underline" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  <% end %>

</div>
