<%# 館一覧ページ — ログイン後のホーム画面 %>
<%# @zones: id順（シード登録順）で全館を表示 %>

<div class="max-w-2xl lg:max-w-4xl mx-auto">

  <div class="mb-6">
    <h1 class="text-xl font-bold text-gray-900">관 목록</h1>
    <p class="text-sm text-gray-500 mt-1">관리 중인 동물 구역</p>
  </div>

  <div class="grid grid-cols-1 gap-3 lg:grid-cols-2 lg:gap-4">
    <% @zones.each do |zone| %>
      <%= link_to zone_path(zone),
          class: "bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:shadow-md hover:border-gray-300 transition-all block" do %>
        <div class="flex items-center justify-between">
          <div class="min-w-0 flex-1">
            <h2 class="text-base font-semibold text-gray-900"><%= zone.name %></h2>
            <% if zone.description.present? %>
              <p class="text-sm text-gray-500 mt-1 line-clamp-2"><%= zone.description %></p>
            <% end %>
          </div>
          <svg class="w-5 h-5 text-gray-400 shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </div>
      <% end %>
    <% end %>
  </div>

</div>
