<%# 売上記録フォーム（new/edit共用） %>
<%= form_with model: sales_record do |f| %>

  <% if sales_record.errors.any? %>
    <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
      <p class="text-sm font-medium text-red-800 mb-2">입력 오류가 있습니다.</p>
      <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
        <% sales_record.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm space-y-4">

    <div>
      <%= f.label :sold_on, "매출 발생일", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :sold_on,
          class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :source, "판매처", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :source,
          [["자판기 1", "vending_1"], ["자판기 2", "vending_2"], ["자판기 3", "vending_3"], ["자판기 4", "vending_4"], ["매점", "stall"]],
          {},
          class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" %>
    </div>

    <div>
      <%= f.label :amount, "매출액 (원)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :amount,
          step: 1, min: 0,
          class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-blue-500",
          placeholder: "예: 15000" %>
    </div>

    <div>
      <%= f.label :note, "특이사항 (선택)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :note,
          rows: 3,
          class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none",
          placeholder: "예: 자판기 고장으로 오후에 재개" %>
    </div>

  </div>

  <div class="mt-4 flex flex-col gap-3">
    <%= f.submit sales_record.persisted? ? "저장" : "등록",
        class: "w-full h-11 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
    <%= link_to "취소", sales_records_path,
        class: "w-full h-11 inline-flex items-center justify-center bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors" %>
  </div>

<% end %>
