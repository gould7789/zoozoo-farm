<%# デスクトップ用サイドバーナビゲーション — lg以上で固定表示 %>
<div class="flex flex-col h-full">

  <%# ロゴ・ユーザー情報 %>
  <div class="px-4 pt-0 pb-2 border-b border-gray-200">
    <div class="flex justify-center -mt-10 -mb-10">
      <%= link_to image_tag("main_logo.png", alt: "Zoo Zoo Farm", class: "w-52 object-contain drop-shadow-md hover:opacity-90 transition-opacity"), zones_path, class: "inline-block" %>
    </div>
    <%# ユーザープロフィール — 将来的にプロフィール写真を追加予定 %>
    <div class="flex items-center gap-3 px-2 py-2 relative z-10">
      <%= link_to account_path, class: "w-9 h-9 rounded-full bg-green-100 flex items-center justify-center shrink-0 hover:bg-green-200 transition-colors" do %>
        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
      <% end %>
      <div class="min-w-0">
        <p class="text-sm font-medium text-gray-800 truncate"><%= current_user.name %></p>
        <span class="inline-block text-xs px-2 py-0.5 rounded-full <%= current_user.admin? ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %>">
          <%= current_user.admin? ? "관리자" : "스태프" %>
        </span>
      </div>
    </div>
  </div>

  <%# ナビゲーションリンク %>
  <nav class="flex-1 px-3 py-2 space-y-1 overflow-y-auto">

    <%= link_to zones_path, class: sidebar_link_class(zones_path) do %>
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
      </svg>
      관 목록
    <% end %>

    <%= link_to notices_path, class: sidebar_link_class(notices_path) do %>
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
      </svg>
      공지
    <% end %>

    <% if current_user.admin? %>
      <div class="pt-3 pb-1">
        <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">관리자</p>
      </div>

      <%= link_to sales_records_path, class: sidebar_link_class(sales_records_path) do %>
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
        </svg>
        매출 기록
      <% end %>

      <%= link_to expense_records_path, class: sidebar_link_class(expense_records_path) do %>
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
        </svg>
        지출 기록
      <% end %>

      <%= link_to admin_users_path, class: sidebar_link_class(admin_users_path) do %>
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
        </svg>
        직원 관리
      <% end %>
    <% end %>

    <%# マイページ — ナビゲーション最下部 %>
    <div class="pt-3 mt-2 border-t border-gray-200">
      <%= link_to account_path, class: sidebar_link_class(account_path) do %>
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
        내 정보
      <% end %>
    </div>

  </nav>

  <%# ログアウト %>
  <div class="px-3 py-3 border-t border-gray-200">
    <%= button_to logout_path, method: :delete,
        class: "w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 hover:bg-red-50 hover:text-red-600 transition-colors group" do %>
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
      </svg>
      로그아웃
    <% end %>
  </div>

</div>
