<%# 売上記録一覧ページ — Admin専用 %>

<div class="max-w-2xl lg:max-w-4xl mx-auto">

  <%# モバイルのみ表示 — 管理ハブへの戻るボタン %>
  <%= link_to admin_dashboard_path, class: "lg:hidden inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
    관리
  <% end %>

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">매출 기록</h1>
    <%= link_to new_sales_record_path,
        class: "inline-flex items-center gap-1.5 h-9 px-3 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      추가
    <% end %>
  </div>

  <%# 2段ナビゲーション：年 → 月 %>
  <% if @all_years.any? %>
    <%# 1段目：年ボタン %>
    <div class="flex flex-wrap gap-2 mb-2">
      <% @all_years.each do |year| %>
        <% year_active = (year == @selected_year) %>
        <%= link_to sales_records_path(year: year),
            class: "inline-flex items-center h-8 px-4 rounded-lg text-xs font-bold transition-colors #{year_active ? 'bg-blue-600 text-white' : 'bg-white border border-gray-200 text-gray-600 hover:bg-gray-50'}" do %>
          <%= year %>
        <% end %>
      <% end %>
    </div>
    <%# 2段目：選択年の月ボタン %>
    <div class="flex flex-wrap gap-2 mb-6">
      <% (@months_by_year[@selected_year] || []).each do |month| %>
        <% month_active = (month == @selected_month) %>
        <%= link_to sales_records_path(year: @selected_year, month: month),
            class: "inline-flex items-center h-8 px-3 rounded-lg text-xs font-medium transition-colors #{month_active ? 'bg-blue-100 text-blue-700 border border-blue-300' : 'bg-white border border-gray-200 text-gray-500 hover:bg-gray-50'}" do %>
          <%= "%02d" % month %>월
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @all_years.empty? %>
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
      <p class="text-gray-400 text-sm">매출 기록이 없습니다.</p>
    </div>
  <% else %>

    <%# 판매처 라벨 %>
    <% source_label = {
      "vending_1" => "자판기 1",
      "vending_2" => "자판기 2",
      "vending_3" => "자판기 3",
      "vending_4" => "자판기 4",
      "stall"     => "가판"
    } %>

    <%# 選択月ヘッダー + 합계 %>
    <% monthly_total = @sales_records.sum(&:amount) %>
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-4">
      <p class="text-xs font-medium text-blue-600 mb-1"><%= @selected_year %>년 <%= "%02d" % @selected_month %>월 총 매출</p>
      <p class="text-2xl font-bold text-blue-900"><%= number_with_delimiter(monthly_total) %>원</p>
      <p class="text-xs text-blue-500 mt-0.5"><%= @sales_records.size %>건</p>
    </div>

    <% if @sales_records.empty? %>
      <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
        <p class="text-gray-400 text-sm">해당 월의 매출 기록이 없습니다.</p>
      </div>
    <% else %>

      <%# モバイルカードリスト %>
      <div class="space-y-3 lg:hidden">
        <% @sales_records.each do |sr| %>
          <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
            <div class="flex items-start justify-between mb-2">
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= sr.sold_on.strftime("%Y-%m-%d") %></p>
                <span class="inline-block mt-1 px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded-full">
                  <%= source_label[sr.source] || sr.source %>
                </span>
              </div>
              <p class="text-lg font-bold text-gray-900"><%= number_with_delimiter(sr.amount) %>원</p>
            </div>
            <% if sr.note.present? %>
              <p class="text-sm text-gray-600"><%= sr.note %></p>
            <% end %>
            <div class="flex gap-2 mt-3 pt-3 border-t border-gray-100">
              <%= link_to "수정", edit_sales_record_path(sr),
                  class: "flex-1 inline-flex items-center justify-center h-9 text-xs font-medium text-gray-600 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors" %>
              <%= button_to "삭제", sales_record_path(sr),
                  method: :delete,
                  data: { turbo_confirm: "정말 삭제하시겠습니까?" },
                  form: { class: "flex-1" },
                  class: "w-full inline-flex items-center justify-center h-9 text-xs font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>

      <%# デスクトップテーブル %>
      <div class="hidden lg:block bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">날짜</th>
              <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">판매처</th>
              <th class="text-right px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">매출액</th>
              <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">특이사항</th>
              <th class="px-5 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @sales_records.each do |sr| %>
              <tr class="hover:bg-gray-50">
                <td class="px-5 py-3.5 font-medium text-gray-900"><%= sr.sold_on.strftime("%Y-%m-%d") %></td>
                <td class="px-5 py-3.5">
                  <span class="inline-block px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded-full">
                    <%= source_label[sr.source] || sr.source %>
                  </span>
                </td>
                <td class="px-5 py-3.5 text-right font-semibold text-gray-900"><%= number_with_delimiter(sr.amount) %>원</td>
                <td class="px-5 py-3.5 text-gray-500 max-w-xs truncate"><%= sr.note.presence || "—" %></td>
                <td class="px-5 py-3.5">
                  <div class="flex items-center gap-2 justify-end">
                    <%= link_to "수정", edit_sales_record_path(sr), class: "text-xs text-blue-600 hover:underline" %>
                    <%= button_to "삭제", sales_record_path(sr),
                        method: :delete,
                        data: { turbo_confirm: "정말 삭제하시겠습니까?" },
                        form: { class: "contents" },
                        class: "text-xs text-red-500 hover:underline" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

    <% end %>
  <% end %>

</div>
