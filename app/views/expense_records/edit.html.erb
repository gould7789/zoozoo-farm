<%# 支出記録編集ページ — Admin専用 %>

<div class="max-w-lg mx-auto">

  <div class="flex items-center gap-3 mb-6 bg-white/80 backdrop-blur-sm rounded-xl px-5 py-4 shadow-sm">
    <%= link_to expense_records_path, class: "text-gray-500 hover:text-gray-700 transition-colors shrink-0" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
    <% end %>
    <div>
      <p class="text-xs text-gray-400"><%= @expense_record.spent_on.strftime("%Y-%m-%d") %></p>
      <h1 class="text-xl font-bold text-gray-900">지출 기록 수정</h1>
    </div>
  </div>

  <%= render "form", expense_record: @expense_record %>

</div>
