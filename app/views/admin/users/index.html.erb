<%# ユーザー管理一覧ページ — Admin専用 %>

<div class="max-w-2xl lg:max-w-4xl mx-auto">

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">직원 관리</h1>
    <%= link_to new_admin_user_path,
        class: "inline-flex items-center gap-1.5 h-9 px-3 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      새 계정 생성
    <% end %>
  </div>

  <% if @users.empty? %>
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
      <p class="text-gray-400 text-sm">등록된 직원이 없습니다.</p>
    </div>
  <% else %>

    <%# モバイルカードリスト %>
    <div class="space-y-3 lg:hidden">
      <% @users.each do |user| %>
        <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
          <div class="flex items-start justify-between">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 flex-wrap">
                <p class="text-sm font-semibold text-gray-900"><%= user.name %></p>
                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium <%= user.admin? ? 'bg-purple-100 text-purple-700' : 'bg-gray-100 text-gray-600' %>">
                  <%= user.admin? ? "관리자" : "스태프" %>
                </span>
                <% unless user.active? %>
                  <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">퇴사</span>
                <% end %>
              </div>
              <p class="text-xs text-gray-400 mt-1 truncate"><%= user.email %></p>
            </div>
            <%= link_to "수정", edit_admin_user_path(user),
                class: "shrink-0 ml-3 inline-flex items-center justify-center h-9 w-16 text-xs font-medium text-gray-600 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>

    <%# デスクトップテーブル %>
    <div class="hidden lg:block bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">이름</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">이메일</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">역할</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">재직 상태</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @users.each do |user| %>
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-3.5 font-medium text-gray-900"><%= user.name %></td>
              <td class="px-5 py-3.5 text-gray-500"><%= user.email %></td>
              <td class="px-5 py-3.5">
                <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium <%= user.admin? ? 'bg-purple-100 text-purple-700' : 'bg-gray-100 text-gray-600' %>">
                  <%= user.admin? ? "관리자" : "스태프" %>
                </span>
              </td>
              <td class="px-5 py-3.5">
                <% if user.active? %>
                  <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">재직 중</span>
                <% else %>
                  <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">퇴사</span>
                <% end %>
              </td>
              <td class="px-5 py-3.5 text-right">
                <%= link_to "수정", edit_admin_user_path(user), class: "text-xs text-blue-600 hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  <% end %>

</div>
