<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Zoo Zoo Farm" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Zoo Zoo Farm">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">

    <%# フラッシュメッセージ %>
    <%= render "layouts/flash" %>

    <% if logged_in? %>
      <%# デスクトップ用サイドバー — lg以上でのみ表示 %>
      <div class="hidden lg:flex lg:fixed lg:inset-y-0 lg:w-64 lg:flex-col lg:bg-white lg:border-r lg:border-gray-200 lg:z-30">
        <%= render "layouts/sidebar" %>
      </div>
    <% end %>

    <%# メインコンテンツ %>
    <main class="<%= logged_in? ? 'lg:ml-64 pb-20 lg:pb-0 px-4 lg:px-8 pt-6' : '' %> min-h-screen">
      <%= yield %>
    </main>

    <% if logged_in? %>
      <%# モバイル用下部タブバー — lg以上では非表示 %>
      <nav class="lg:hidden fixed bottom-0 inset-x-0 bg-white border-t border-gray-200 z-30">
        <%= render "layouts/bottom_nav" %>
      </nav>
    <% end %>

  </body>
</html>
