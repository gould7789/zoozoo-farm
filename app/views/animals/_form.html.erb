<%# 動物登録・編集の共通フォーム %>
<%# new.html.erb と edit.html.erb から render "form" で呼び出す %>
<%= form_with model: [@zone, @animal], data: { controller: "form", action: "submit->form#submit" } do |f| %>

  <%# バリデーションエラー表示 %>
  <% if @animal.errors.any? %>
    <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
      <p class="text-sm font-medium text-red-800 mb-2">입력 오류가 있습니다.</p>
      <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
        <% @animal.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm space-y-4">

    <div>
      <%= f.label :species, "종 이름", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :species,
          class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-green-500",
          placeholder: "예: 라쿤" %>
    </div>

    <div>
      <%# 個体名は任意（多頭飼育種は空白のまま） %>
      <%= f.label :name, "개체명 (선택)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
          class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-green-500",
          placeholder: "예: 오몽이 (여러 마리인 경우 비워도 됩니다)" %>
    </div>

    <div>
      <%= f.label :gender, "성별", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :gender,
          [["수컷", "male"], ["암컷", "female"], ["미확인", "unknown"]],
          {},
          class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-green-500 bg-white" %>
    </div>

    <div>
      <%# 生年月日は不明の場合は空白 %>
      <%= f.label :birth_date, "생년월일 (선택)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :birth_date,
          class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-green-500" %>
      <p class="text-xs text-gray-400 mt-1">생년월일을 모르는 경우 입수일을 참고해 입력해주세요.</p>
    </div>

    <div>
      <%= f.label :acquired_at, "입수일 (선택)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :acquired_at,
          class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-green-500" %>
    </div>

    <div>
      <%= f.label :acquisition_note, "입수 경위 (선택)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :acquisition_note,
          rows: 3,
          class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-green-500 resize-none overflow-hidden",
          placeholder: "예: 구매, 기증, 자연번식 등",
          data: { controller: "textarea", action: "input->textarea#resize" } %>
    </div>

    <div>
      <%# CITES区分 — 許可証の実物は書類で保管、システムには区分のみ記録 %>
      <%= f.label :cites_grade, "CITES 등급", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :cites_grade,
          [["해당 없음", "none"], ["부속서 I", "grade_i"], ["부속서 II", "grade_ii"], ["부속서 III", "grade_iii"]],
          {},
          class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-green-500 bg-white" %>
    </div>

    <div>
      <%# 先天性疾患・性格など固定の特記事項 %>
      <%= f.label :note, "특이사항 (선택)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :note,
          rows: 3,
          class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-green-500 resize-none overflow-hidden",
          placeholder: "선천적 기형, 성격 등 고정 특이사항",
          data: { controller: "textarea", action: "input->textarea#resize" } %>
    </div>

  </div>

  <div class="mt-4 flex flex-col gap-3">
    <%= f.submit @animal.persisted? ? "저장" : "등록",
        class: "w-full h-11 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-lg transition-colors cursor-pointer",
        data: { form_target: "submit" } %>
    <%= link_to "취소", @animal.persisted? ? zone_animal_path(@zone, @animal) : zone_path(@zone),
        class: "w-full h-11 inline-flex items-center justify-center bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors" %>
  </div>

<% end %>
