<%# 動物詳細ページ — 個体プロフィールを表示 %>
<%# 編集・削除ボタンはAdmin専用 %>

<div class="max-w-2xl mx-auto">

  <%# ヘッダー — 戻るリンク %>
  <div class="flex items-center gap-3 mb-6">
    <%= link_to zone_path(@zone), class: "text-gray-400 hover:text-gray-600 transition-colors shrink-0" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
    <% end %>
    <div>
      <p class="text-xs text-gray-400"><%= @zone.name %></p>
      <h1 class="text-xl font-bold text-gray-900">
        <%= @animal.species %>
        <% if @animal.name.present? %>
          <span class="text-base font-normal text-gray-500">（<%= @animal.name %>）</span>
        <% end %>
      </h1>
    </div>
  </div>

  <%# プロフィールカード %>
  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm mb-4">
    <dl class="grid grid-cols-2 gap-x-4 gap-y-4">

      <div>
        <dt class="text-xs text-gray-400 mb-0.5">관</dt>
        <dd class="text-sm font-medium text-gray-900">
          <%= link_to @zone.name, zone_path(@zone), class: "text-blue-600 hover:underline" %>
        </dd>
      </div>

      <div>
        <dt class="text-xs text-gray-400 mb-0.5">성별</dt>
        <dd class="text-sm font-medium text-gray-900"><%= @animal.gender %></dd>
      </div>

      <% if @animal.birth_date.present? %>
        <div>
          <dt class="text-xs text-gray-400 mb-0.5">생년월일</dt>
          <dd class="text-sm font-medium text-gray-900"><%= @animal.birth_date %></dd>
        </div>
      <% end %>

      <% if @animal.acquired_at.present? %>
        <div>
          <dt class="text-xs text-gray-400 mb-0.5">입수일</dt>
          <dd class="text-sm font-medium text-gray-900"><%= @animal.acquired_at %></dd>
        </div>
      <% end %>

      <div>
        <dt class="text-xs text-gray-400 mb-0.5">CITES 등급</dt>
        <dd class="text-sm font-medium text-gray-900">
          <% if @animal.cites_grade == "none" %>
            <span class="text-gray-400">해당 없음</span>
          <% else %>
            <span class="inline-block px-2 py-0.5 bg-amber-100 text-amber-800 text-xs rounded-full font-semibold">
              <%= @animal.cites_grade.upcase %>
            </span>
          <% end %>
        </dd>
      </div>

    </dl>

    <% if @animal.acquisition_note.present? %>
      <div class="mt-4 pt-4 border-t border-gray-100">
        <dt class="text-xs text-gray-400 mb-1">입수 경위</dt>
        <dd class="text-sm text-gray-700"><%= @animal.acquisition_note %></dd>
      </div>
    <% end %>

    <% if @animal.note.present? %>
      <div class="mt-4 pt-4 border-t border-gray-100">
        <dt class="text-xs text-gray-400 mb-1">특이사항</dt>
        <dd class="text-sm text-gray-700"><%= @animal.note %></dd>
      </div>
    <% end %>
  </div>

  <%# 記録ナビゲーション — 健康記録・給餌記録 %>
  <div class="grid grid-cols-2 gap-3 mb-6">
    <%= link_to zone_animal_health_records_path(@zone, @animal),
        class: "bg-white rounded-xl border border-gray-200 p-4 shadow-sm hover:shadow-md transition-all text-center block" do %>
      <p class="text-sm font-semibold text-gray-900">건강 기록</p>
      <p class="text-xs text-gray-400 mt-0.5">컨디션 · 체중</p>
    <% end %>
    <%= link_to zone_animal_feeding_records_path(@zone, @animal),
        class: "bg-white rounded-xl border border-gray-200 p-4 shadow-sm hover:shadow-md transition-all text-center block" do %>
      <p class="text-sm font-semibold text-gray-900">먹이 기록</p>
      <p class="text-xs text-gray-400 mt-0.5">급여 이력</p>
    <% end %>
  </div>

  <%# 編集・削除はAdmin専用 — Staffには非表示 %>
  <% if current_user.admin? %>
    <div class="flex gap-3">
      <%= link_to "수정", edit_zone_animal_path(@zone, @animal),
          class: "flex-1 inline-flex items-center justify-center h-11 px-4 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors" %>
      <%= button_to "삭제", zone_animal_path(@zone, @animal), method: :delete,
          data: { turbo_confirm: "정말 삭제하시겠습니까?" },
          class: "flex-1 inline-flex items-center justify-center h-11 px-4 bg-red-500 hover:bg-red-600 text-white text-sm font-medium rounded-lg transition-colors" %>
    </div>
  <% end %>

</div>
