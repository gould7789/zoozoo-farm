<%# カテゴリ名編集ページ — Admin専用 %>
<% content_for(:title, "카테고리 수정") %>

<div class="max-w-2xl md:max-w-4xl mx-auto">

  <%# ヘッダー %>
  <div class="flex items-center gap-3 mb-6 bg-white/80 backdrop-blur-sm rounded-xl px-5 py-4 shadow-sm">
    <%= link_to zone_animal_categories_path(@zone), class: "text-gray-400 hover:text-gray-600 transition-colors shrink-0" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
    <% end %>
    <div class="min-w-0">
      <h1 class="text-xl font-bold text-gray-900">카테고리 수정</h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= @zone.name %></p>
    </div>
  </div>

  <%# 編集フォーム %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
    <%= form_with model: [ @zone, @category ] do |f| %>
      <% if @category.errors.any? %>
        <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
          <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
            <% @category.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div class="mb-4">
        <%= f.label :name, "카테고리 이름", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name,
            class: "w-full h-11 px-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-green-500" %>
      </div>
      <div class="flex flex-col gap-3">
        <%= f.submit "저장",
            class: "w-full h-11 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "취소", zone_animal_categories_path(@zone),
            class: "w-full h-11 inline-flex items-center justify-center bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors" %>
      </div>
    <% end %>
  </div>

</div>
