<%# 健康記録一覧ページ %>
<h1><%= @animal.species %> の健康記録</h1>

<%= link_to "新規記録", new_zone_animal_health_record_path(@zone, @animal) %>

<% @health_records.each do |hr| %>
  <div>
    <p><%= hr.recorded_on %> — <%= hr.condition %></p>
    <% if current_user.admin? || hr.created_by_id == current_user.id %>
      <%= link_to "編集", edit_zone_animal_health_record_path(@zone, @animal, hr) %>
      <%= button_to "削除", zone_animal_health_record_path(@zone, @animal, hr), method: :delete, data: { turbo_confirm: "削除しますか？" } %>
    <% end %>
  </div>
<% end %>
